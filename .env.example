# Backend Server Configuration
# Copy this file to .env and fill in your actual values

# Server
PORT=5000
NODE_ENV=development

# Firebase Admin SDK
# Generate a service account key from Firebase Console -> Project Settings -> Service Accounts
# Option 1: Pass the entire JSON as a single string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id"...}'

# Option 2: Or set individual Firebase credentials if using ADC
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Gemini API
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
# Comma-separated list of allowed origins (in addition to localhost defaults)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: Database
# DATABASE_URL=your_database_url

# Optional: Logging
# LOG_LEVEL=debug
